{
  "name": "chronos-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @chronos/backend dev & pnpm --filter @chronos/frontend dev",
    "build": "pnpm -r build",
    "dev:backend": "pnpm --filter @chronos/backend dev",
    "dev:frontend": "pnpm --filter @chronos/frontend dev",
    "db:generate": "pnpm --filter @chronos/backend db:generate",
    "db:migrate": "pnpm --filter @chronos/backend db:migrate",
    "db:push": "pnpm --filter @chronos/backend db:push",
    "db:studio": "pnpm --filter @chronos/backend db:studio"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "@codemirror/state": "^6.6.0",
      "@codemirror/view": "^6.40.0"
    }
  }
}
