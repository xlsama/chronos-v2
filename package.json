{
  "name": "chronos-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @chronos/backend dev & pnpm --filter @chronos/frontend dev",
    "build": "pnpm -r build",
    "dev:backend": "pnpm --filter @chronos/backend dev",
    "dev:frontend": "pnpm --filter @chronos/frontend dev",
    "db:generate": "pnpm --filter @chronos/backend db:generate",
    "db:migrate": "pnpm --filter @chronos/backend db:migrate",
    "db:push": "pnpm --filter @chronos/backend db:push",
    "db:studio": "pnpm --filter @chronos/backend db:studio",
    "test:integration": "vitest run --config tests/vitest.config.ts",
    "test:case-1": "vitest run --config tests/vitest.config.ts case-1",
    "test:case-2": "vitest run --config tests/vitest.config.ts case-2",
    "test:case-3": "vitest run --config tests/vitest.config.ts case-3",
    "test:case-4": "vitest run --config tests/vitest.config.ts case-4",
    "test:case-5": "vitest run --config tests/vitest.config.ts case-5"
  },
  "devDependencies": {
    "ioredis": "^5.10.0",
    "mysql2": "^3.19.1",
    "postgres": "^3.4.8",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "@codemirror/state": "^6.6.0",
      "@codemirror/view": "^6.40.0"
    },
    "patchedDependencies": {
      "@mastra/core": "patches/@mastra__core.patch"
    }
  }
}
